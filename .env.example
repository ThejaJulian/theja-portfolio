# Copy to `.env.local` for local development. In Vercel, add these under Project → Settings → Environment Variables.

# EmailJS (https://www.emailjs.com/) — template should include {{from_name}}, {{reply_to}}, {{message}}
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
